# Statutory — environment variables (names only; never commit values).
# See TOOLS.md for what each key is for. Local dev DB matches docker-compose.yml.

DATABASE_URL=postgres://statutory:statutory@localhost:5434/statutory_dev

# LLM (triage + synthesis). Absent => deterministic mock adapters are used.
ANTHROPIC_API_KEY=

# Government data sources (all free; api.data.gov keys where noted)
GOVINFO_API_KEY=
REGULATIONS_GOV_API_KEY=
OPENSTATES_API_KEY=
COURTLISTENER_API_TOKEN=

# Delivery
RESEND_API_KEY=

# Pipeline scheduling (prod only; local dev server needs none)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Billing (M3). Absent STRIPE_SECRET_KEY => deterministic mock provider.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE=
STRIPE_PRICE_PRACTICE_PRO=
STRIPE_PRICE_SMALL_FIRM=
STRIPE_PRICE_JURISDICTION_ADDON=
