{
  "name": "@statutory/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema, migrations, and the publish-path repository for the Statutory data model (Postgres + pgvector). The approved-before-publish gate is enforced by DB triggers (M2).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "migrate": "node ./scripts/migrate.mjs",
    "generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@statutory/core": "workspace:*",
    "@statutory/pipeline": "workspace:*",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^6.0.3"
  }
}
