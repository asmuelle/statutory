{
  "name": "statutory",
  "version": "0.1.0",
  "private": true,
  "description": "Living rulebook of statutes, agency rules, and rates for solo professionals — span-verified deltas pushed when monitored sources change.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm --filter @statutory/web dev",
    "test": "vitest run --coverage",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:live": "vitest run --config vitest.live.config.ts",
    "daily": "tsx packages/pipeline/src/daily/cli.ts",
    "e2e": "pnpm --filter @statutory/web e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10",
      "flatted": ">=3.4.2",
      "js-yaml": ">=4.2.0",
      "picomatch@4": ">=4.0.4",
      "minimatch@3": ">=3.1.3",
      "minimatch@9": ">=9.0.7"
    }
  }
}
