{
  "name": "statutory",
  "version": "0.1.0",
  "private": true,
  "description": "Living rulebook of statutes, agency rules, and rates for solo professionals — span-verified deltas pushed when monitored sources change.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm --filter @statutory/web dev",
    "test": "vitest run --coverage",
    "test:db": "vitest run --config vitest.db.config.ts",
    "e2e": "pnpm --filter @statutory/web e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
